[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-e": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "ctrl-j": "workspace::ToggleBottomDock",
      "shift-h": "pane::ActivatePreviousItem",
      "shift-l": "pane::ActivateNextItem",

      "alt-shift-h": "pane::SwapItemLeft",
      "alt-shift-l": "pane::SwapItemRight",

      "ctrl-w": "pane::CloseActiveItem",
      "ctrl-e": "workspace::ToggleLeftDock",
      "] g": "editor::GoToDiagnostic",
      "[ g": "editor::GoToPreviousDiagnostic",
      "ctrl-shift-space": "editor::ShowSignatureHelp",
      "ctrl-k": "editor::ShowSignatureHelp"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-e": "workspace::ToggleLeftDock",
      "space p f": "file_finder::Toggle"
    }
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore"
    }
  },
  {
    "context": "Editor && vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      "ctrl-space h": "workspace::ActivatePreviousPane",
      "ctrl-space l": "workspace::ActivateNextPane",
      "` h": "workspace::ActivatePreviousPane",
      "` l": "workspace::ActivateNextPane"
    }
  },
  {
    "context": "Editor && !showing_signature_help && !showing_completions",
    "bindings": {
      "ctrl-k": "editor::ShowSignatureHelp"
    }
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space p g": "pane::DeploySearch",
      "space w": "editor::ToggleFold",
      "s v": "pane::SplitRight",
      "s s": "pane::SplitDown",
      "g d": "editor::GoToDefinition"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-space h": "workspace::ActivatePreviousPane",
      "ctrl-space l": "workspace::ActivateNextPane",
      "` h": "workspace::ActivatePreviousPane",
      "` l": "workspace::ActivateNextPane",
      "ctrl-t": "workspace::NewTerminal"
    }
  }
]

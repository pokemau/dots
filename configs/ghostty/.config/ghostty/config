# FONT
# font-family = Roboto Mono Nerd Font Mono
font-family = Menlo Nerd Font
font-style = medium
font-size = 11
font-feature = -calt
font-feature = -liga
font-feature = -dlig
# adjust-cell-height = -1
# adjust-cell-width = -1

# WINDOW CONFIGURATION
# window-padding-x = 4
# window-padding-y = 4
# background-opacity = 1.0
gtk-titlebar-hide-when-maximized = true

# CURSOR CONFIGURATION
cursor-style = block
cursor-style-blink = true
#
# SCROLLBACK
scrollback-limit = 3023

# TERMINAL FEATURES
copy-on-select = true

# DISABLE ANNOYING COPIED TO CLIPBOARD
app-notifications = no-clipboard-copy,no-config-reload
#
# SHELL INTEGRATION
shell-integration = detect
shell-integration-features = cursor,sudo,title,no-cursor
keybind = shift+enter=text:\n

# RANDO STUFF
gtk-single-instance = false


# GRUVBOX MATERIAL DARK COLORS
background = #17191a
foreground = #d4be98
selection-background = #504945
selection-foreground = #d4be98
cursor-color = #d4be98
cursor-text = #17191a
cursor-invert-fg-bg = true
palette = 0=#32302f
palette = 1=#ea6962
palette = 2=#a9b665
palette = 3=#d8a657
palette = 4=#7daea3
palette = 5=#d3869b
